@startuml
left to right direction
skinparam packageStyle rectangle

actor "Khách hàng (Customer)" as Customer
actor "Quản trị viên (Admin)" as Admin

rectangle "Hệ thống bán trang sức trực tuyến" {

  usecase "Quản lý tài khoản" as UC01
  usecase "Đăng ký" as UC01a
  usecase "Đăng nhập Google" as UC01b
  usecase "Quên mật khẩu" as UC01c
  usecase "Quản lý thông tin cá nhân" as UC01d
  usecase "Khám phá sản phẩm" as UC02
  usecase "Tìm kiếm và lọc sản phẩm" as UC03
  usecase "Xem chi tiết sản phẩm" as UC04
  usecase "Quản lý giỏ hàng và khuyến mãi" as UC05
  usecase "Đặt hàng và thanh toán" as UC06
  usecase "Quản lý đơn hàng" as UC07
  usecase "Theo dõi đơn hàng" as UC07a
  usecase "Hủy đơn hàng" as UC07b
  usecase "Mua lại" as UC07c
  usecase "Đánh giá sản phẩm" as UC08

  usecase "Đăng nhập Admin" as A01
  usecase "Dashboard & Báo cáo" as A02
  usecase "Quản lý sản phẩm" as A03
  usecase "Quản lý thuộc tính" as A03a
  usecase "Quản lý kho" as A04
  usecase "Quản lý đơn hàng" as A05
  usecase "Quản lý khách hàng" as A06
  usecase "Quản lý khuyến mãi" as A07
  usecase "Quản lý đánh giá" as A08
  usecase "Quản lý nội dung (banner)" as A09

  ' Quan hệ include/extend cho Customer
  UC01 ..> UC01a : includes
  UC01 ..> UC01b : includes
  UC01 ..> UC01c : includes
  UC01 ..> UC01d : includes

  UC07 ..> UC07a : includes
  UC07 ..> UC07b : includes
  UC07 ..> UC07c : includes

  ' Quan hệ include cho Admin
  A03 ..> A03a : includes

  ' Kết nối actor với use case
  Customer --> UC01
  Customer --> UC02
  Customer --> UC03
  Customer --> UC04
  Customer --> UC05
  Customer --> UC06
  Customer --> UC07
  Customer --> UC08

  Admin --> A01
  Admin --> A02
  Admin --> A03
  Admin --> A04
  Admin --> A05
  Admin --> A06
  Admin --> A07
  Admin --> A08
  Admin --> A09
}

@enduml