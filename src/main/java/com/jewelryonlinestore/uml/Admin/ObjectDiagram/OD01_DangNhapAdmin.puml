@startuml
title Object Diagram - Đăng Nhập Admin (Trường hợp thành công)

object "request: LoginRequest" as req {
  email = "admin@jewelry.com"
  password = "Password123!"
}

object "authCtrl: AuthController" as ctrl {
}

object "authSvc: AuthServiceImpl" as svc {
}

object "adminUser: User" as user {
  id = 1
  email = "admin@jewelry.com"
  passwordHash = "$2a$10$abcxyz123..."
  role = Role.ADMIN
  status = Status.ACTIVE
}

object "loginLog: AdminActionsLog" as log {
  id = 105
  adminId = 1
  action = "ADMIN_LOGIN_SUCCESS"
  timestamp = "2026-04-04T10:45:00"
}

req --> ctrl : "gửi tới"
ctrl --> svc : "authenticateAdmin(req)"
svc --> user : "tìm thấy và xác thực"
svc --> log : "tạo mới log"

@enduml