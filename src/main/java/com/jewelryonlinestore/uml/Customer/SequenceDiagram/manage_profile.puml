@startuml
title Sequence Diagram - Use Case: Quản lý thông tin cá nhân
actor "Customer" as C
participant "UI" as UI
participant "AccountController" as Ctrl
participant "AuthService" as AuthSvc
participant "CustomerService" as CustSvc
participant "AddressService" as AddrSvc
participant "Database" as DB

C -> UI: Chọn "Tài khoản của tôi"
UI -> Ctrl: GET /account
Ctrl -> CustSvc: getCustomerByUserId(session.userId)
CustSvc -> DB: query
DB --> CustSvc: Customer & Addresses
CustSvc --> Ctrl: data
Ctrl --> UI: Render trang Quản lý tài khoản

alt a. Cập nhật hồ sơ cá nhân
    C -> UI: Sửa thông tin & Lưu
    UI -> Ctrl: POST /account/profile (UpdateProfileRequest)
    Ctrl -> CustSvc: updateProfile(userId, request)
    CustSvc -> DB: UPDATE customers SET...
    DB --> CustSvc: OK
    CustSvc --> Ctrl: Success
    Ctrl --> UI: Hiển thị thông báo thành công

else b. Thay đổi mật khẩu
    C -> UI: Nhập pass cũ, pass mới & Lưu
    UI -> Ctrl: POST /account/password (ChangePasswordRequest)
    Ctrl -> AuthSvc: changePassword(userId, request)
    AuthSvc -> DB: SELECT password_hash FROM users
    alt Mật khẩu cũ sai (E1)
        AuthSvc --> Ctrl: throw Exception("Sai mật khẩu cũ")
        Ctrl --> UI: Hiển thị lỗi E1
    else Mật khẩu cũ đúng
        AuthSvc -> AuthSvc: hash(newPassword)
        AuthSvc -> DB: UPDATE users SET password_hash = ...
        AuthSvc --> Ctrl: Success
        Ctrl --> UI: Hiển thị thông báo thành công
    end

else c/d/f. Quản lý địa chỉ (Thêm/Sửa/Mặc định)
    C -> UI: Gửi yêu cầu thao tác địa chỉ
    UI -> Ctrl: POST/PUT /account/addresses...
    Ctrl -> AddrSvc: add/update/setDefault()
    AddrSvc -> DB: INSERT/UPDATE addresses
    AddrSvc --> Ctrl: Success
    Ctrl --> UI: Hiển thị thông báo thành công

else e. Xóa địa chỉ
    C -> UI: Nhấn Xóa địa chỉ
    UI -> Ctrl: DELETE /account/addresses/{id}
    Ctrl -> AddrSvc: deleteAddress(id)
    AddrSvc -> DB: SELECT * FROM addresses WHERE id = ...
    alt Là địa chỉ mặc định duy nhất (E2)
        AddrSvc --> Ctrl: throw Exception("Không thể xóa...")
        Ctrl --> UI: Hiển thị lỗi E2
    else Hợp lệ
        AddrSvc -> DB: UPDATE addresses SET is_deleted = true
        AddrSvc --> Ctrl: Success
        Ctrl --> UI: Hiển thị thông báo thành công
    end
end
@enduml