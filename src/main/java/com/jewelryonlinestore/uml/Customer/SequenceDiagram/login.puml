@startuml
title Sequence Diagram - Use Case: Đăng nhập (Local Form)
actor "Actor (Người dùng)" as Actor
participant "Giao diện (UI)" as UI
participant "AuthController" as AuthCtrl
participant "AuthenticationManager" as AuthMgr
participant "UserDetailsServiceImpl" as UserSvc
participant "UserRepository" as Repo
participant "PasswordEncoder" as Encoder

Actor -> UI: Nhập Email, Password & Nhấn "Đăng nhập"
UI -> AuthCtrl: POST /auth/login (email, password)
AuthCtrl -> AuthMgr: authenticate(UsernamePasswordToken)

AuthMgr -> UserSvc: loadUserByUsername(email)
UserSvc -> Repo: findByEmail(email)

alt Email không tồn tại (E1)
    Repo --> UserSvc: null
    UserSvc --> AuthMgr: throw UsernameNotFoundException
    AuthMgr --> AuthCtrl: throw BadCredentialsException
    AuthCtrl --> UI: Báo lỗi "Tên đăng nhập hoặc mật khẩu không đúng"
else Email tồn tại
    Repo --> UserSvc: User Entity
    UserSvc --> AuthMgr: UserDetails

    AuthMgr -> Encoder: matches(rawPassword, encodedPassword)

    alt Mật khẩu sai (E1)
        Encoder --> AuthMgr: false
        AuthMgr --> AuthCtrl: throw BadCredentialsException
        AuthCtrl --> UI: Báo lỗi "Tên đăng nhập hoặc mật khẩu không đúng"
    else Mật khẩu đúng
        Encoder --> AuthMgr: true

        AuthMgr -> AuthMgr: Kiểm tra User status
        alt Trạng thái ≠ ACTIVE (E2)
            AuthMgr --> AuthCtrl: throw DisabledException
            AuthCtrl --> UI: Báo lỗi "Tài khoản của bạn đã bị vô hiệu hóa"
        else Trạng thái == ACTIVE (Main Flow)
            AuthMgr --> AuthCtrl: Authentication (Thành công)

            AuthCtrl -> AuthCtrl: Cấp JWT Token / Lưu Session
            AuthCtrl -> AuthCtrl: Kiểm tra Authorities (Roles)

            alt Role == ROLE_ADMIN
                AuthCtrl --> UI: Redirect (/admin/dashboard)
            else Role == ROLE_CUSTOMER
                AuthCtrl --> UI: Redirect (/)
            end
        end
    end
end
@enduml