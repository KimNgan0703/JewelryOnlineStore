@startuml
title Object Diagram - Trạng thái Đơn hàng thanh toán Momo thành công

object "order_001 : Order" as order {
  id = 5001
  orderNumber = "ORD-04042026-001"
  orderStatus = PENDING
  totalAmount = 8500000
  discountAmount = 500000
  shippingAddress = "123 Lê Lợi, Q1, HCM"
  note = "Giao trong giờ hành chính"
}

object "item_1 : OrderItem" as item1 {
  quantity = 1
  price = 5000000
  productVariantId = 88
}

object "item_2 : OrderItem" as item2 {
  quantity = 1
  price = 4000000
  productVariantId = 95
}

object "payment_info : Payment" as payment {
  paymentMethod = "MOMO"
  paymentStatus = PAID
  transactionId = "MOMO_TRX_987654321"
}

object "history_1 : OrderStatusHistory" as history {
  status = PENDING
  changeTime = "2026-04-04T10:15:00"
}

object "promo : Promotion" as promo {
  code = "GIAM500K"
  discountValue = 500000
}

order *-- item1
order *-- item2
order -- payment
order *-- history
order --> promo : applied_promotion_id

@enduml