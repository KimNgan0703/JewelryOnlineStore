@startuml
title Activity Diagram - Use Case: Quản lý thông tin cá nhân

|Khách hàng (Đã đăng nhập)|
start
:Chọn mục "Tài khoản của tôi";

|Hệ thống|
:Hiển thị trang Quản lý tài khoản;

|Khách hàng (Đã đăng nhập)|
switch (Chọn thao tác?)
case ( a. Xem & Sửa thông tin cá nhân )
  :Sửa Họ tên, Giới tính, Ngày sinh, SĐT;
  :Lưu thay đổi;
  |Hệ thống|
  :Cập nhật bản ghi trong bảng customers;

case ( b. Thay đổi mật khẩu )
  |Khách hàng (Đã đăng nhập)|
  :Nhập Mật khẩu cũ, Mật khẩu mới & Xác nhận;
  :Gửi yêu cầu;
  |Hệ thống|
  :Kiểm tra mật khẩu cũ;
  if (Mật khẩu cũ khớp?) then (Không - E1)
    :Hiển thị lỗi "Mật khẩu hiện tại không chính xác";
    stop
  else (Có)
    :Cập nhật mật khẩu mới (hash BCrypt)\nvào bảng users;
  endif

case ( Quản lý Địa chỉ )
  |Khách hàng (Đã đăng nhập)|
  switch (Thao tác địa chỉ?)
  case ( c. Thêm địa chỉ mới )
    :Nhập thông tin địa chỉ mới & Lưu;
    |Hệ thống|
    :Tạo bản ghi mới trong bảng addresses;
  case ( d. Sửa địa chỉ )
    |Khách hàng (Đã đăng nhập)|
    :Sửa thông tin địa chỉ & Lưu;
    |Hệ thống|
    :Cập nhật bản ghi trong bảng addresses;
  case ( e. Xóa địa chỉ )
    |Hệ thống|
    :Kiểm tra thuộc tính địa chỉ;
    if (Là địa chỉ mặc định duy nhất?) then (Có - E2)
      :Hiển thị "Không thể xóa địa chỉ mặc định duy nhất";
      stop
    else (Không)
      :Đánh dấu is_deleted = true;
    endif
  case ( f. Đặt làm mặc định )
    |Hệ thống|
    :Cập nhật is_default = true cho địa chỉ chọn;
    :Cập nhật is_default = false cho các địa chỉ khác;
  endswitch
endswitch

|Hệ thống|
:Lưu thay đổi vào Database;
:Hiển thị thông báo thành công;
stop

@enduml