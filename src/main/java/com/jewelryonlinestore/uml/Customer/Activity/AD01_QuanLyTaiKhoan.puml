@startuml
title Activity Diagram - Use Case: Đăng ký tài khoản

|Khách hàng|
start
:Nhấn nút "Đăng ký" trên trang chủ;
|Hệ thống|
:Hiển thị form đăng ký (Email, Password);

|Khách hàng|
if (Chọn phương thức đăng ký?) then (Đăng ký thường)
  :Nhập thông tin (Email, Pass, Confirm) và Submit;
  |Hệ thống|
  if (Validate định dạng & khớp mật khẩu?) then (Lỗi)
    :Hiển thị thông báo lỗi (E1);
    stop
  else (Hợp lệ)
    :Kiểm tra email trong DB;
    if (Trạng thái Email?) then (Đã tồn tại & ACTIVE)
      :Thông báo "Email đã đăng ký" (E2);
      stop
    elseif (Đã tồn tại & PENDING)
      :Cho phép gửi lại email xác thực (A1);
      stop
    else (Chưa tồn tại)
      :Hash mật khẩu (BCrypt);
      :Tạo bản ghi User (status = PENDING);
      :Tạo VerificationToken lưu vào DB;
      :Gửi email chứa link xác thực (24h);
    endif
  endif
else (Đăng ký Google OAuth - A2)
  |Hệ thống|
  :Kết nối Google lấy thông tin (Email);
  :Tạo tài khoản tự động (Nếu chưa có);
  :Đăng nhập và chuyển hướng;
  stop
endif

|Khách hàng|
:Mở email và nhấn Link xác thực;
|Hệ thống|
:Kiểm tra Verification Token;
if (Token hợp lệ?) then (Hết hạn / Đã dùng)
  :Thông báo lỗi & Cho phép gửi lại (E3);
  stop
else (Hợp lệ)
  :Cập nhật User status = ACTIVE;
  :Đánh dấu token đã sử dụng;
  :Hiển thị Form bổ sung thông tin cá nhân;

  |Khách hàng|
  :Nhập Họ tên, Ngày sinh, SĐT, Địa chỉ...;
  :Gửi thông tin;

  |Hệ thống|
  :Tạo bản ghi Customer;
  :Tạo bản ghi Address (mặc định);
  :Đăng nhập tự động;
  :Chuyển hướng về Trang chủ;
  stop
endif
@enduml