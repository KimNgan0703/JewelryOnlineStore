@startuml JewelryOnlineStore_ERD
!define primary_key(x) <b><color:#b8861b><&key></color> x</b>
!define foreign_key(x) <color:#aaaaaa><&key></color> x
!define column(x) x
!define table(x) entity x << (T, white) >>

hide circle
hide methods
hide stereotypes

skinparam linetype ortho
skinparam nodesep 50
skinparam ranksep 50
skinparam entity {
    BackgroundColor #FDFDFD
    BorderColor #333333
    HeaderBackgroundColor #E0E8F5
}

' ==========================================
' USER & AUTHENTICATION
' ==========================================
table(users) {
  primary_key(id) : bigint
  --
  email : varchar(255)
  google_id : varchar(255)
  password : varchar(255)
  role : enum('ADMIN','CUSTOMER')
  status : enum('ACTIVE','LOCKED','PENDING')
  created_at : datetime(6)
  updated_at : datetime(6)
}

table(verification_tokens) {
  primary_key(id) : bigint
  --
  foreign_key(user_id) : bigint
  token : varchar(255)
  type : enum('EMAIL_VERIFICATION','PASSWORD_RESET')
  expires_at : datetime(6)
  used_at : datetime(6)
  created_at : datetime(6)
}

table(admin_actions_log) {
  primary_key(id) : bigint
  --
  foreign_key(admin_id) : bigint
  ip_address : varchar(45)
  entity_type : varchar(100)
  action : varchar(255)
  new_data : json
  old_data : json
  entity_id : bigint
  created_at : datetime(6)
}

table(customers) {
  primary_key(id) : bigint
  --
  foreign_key(user_id) : bigint <<UK>>
  phone : varchar(20)
  avatar_url : varchar(500)
  full_name : varchar(255)
  gender : enum('FEMALE','MALE','OTHER')
  birth_date : date
  created_at : datetime(6)
  updated_at : datetime(6)
}

table(addresses) {
  primary_key(id) : bigint
  --
  foreign_key(customer_id) : bigint
  recipient_name : varchar(255)
  phone : varchar(20)
  street_address : varchar(255)
  ward : varchar(100)
  district : varchar(100)
  province : varchar(100)
  is_default : bit(1)
  is_deleted : bit(1)
  created_at : datetime(6)
  updated_at : datetime(6)
}

' ==========================================
' PRODUCTS & CATALOG
' ==========================================
table(categories) {
  primary_key(id) : bigint
  --
  foreign_key(parent_id) : bigint
  name : varchar(255)
  slug : varchar(255)
  description : text
  image_url : varchar(500)
  sort_order : int
  is_active : bit(1)
  created_at : datetime(6)
  updated_at : datetime(6)
}

table(brands) {
  primary_key(id) : bigint
  --
  name : varchar(255)
  slug : varchar(255)
  logo_url : varchar(500)
  description : text
  is_active : bit(1)
  created_at : datetime(6)
  updated_at : datetime(6)
}

table(collections) {
  primary_key(id) : bigint
  --
  name : varchar(255)
  slug : varchar(255)
  image_url : varchar(500)
  description : text
  is_active : bit(1)
  created_at : datetime(6)
  updated_at : datetime(6)
}

table(materials) {
  primary_key(id) : bigint
  --
  name : varchar(255)
  description : text
  created_at : datetime(6)
}

table(products) {
  primary_key(id) : bigint
  --
  foreign_key(category_id) : bigint
  foreign_key(brand_id) : bigint
  foreign_key(collection_id) : bigint
  foreign_key(material_id) : bigint
  name : varchar(255)
  slug : varchar(255)
  sku : varchar(100)
  gender : enum('FEMALE','MALE','UNISEX')
  base_price : decimal(15,0)
  compare_price : decimal(15,0)
  weight_gram : decimal(10,2)
  short_description : text
  description : text
  meta_title : varchar(255)
  meta_description : text
  is_active : bit(1)
  is_best_seller : bit(1)
  is_new : bit(1)
  created_at : datetime(6)
  updated_at : datetime(6)
}

table(product_variants) {
  primary_key(id) : bigint
  --
  foreign_key(product_id) : bigint
  sku : varchar(100)
  size : varchar(50)
  price : decimal(15,0)
  stock_quantity : int
  low_stock_threshold : int
  is_active : bit(1)
  created_at : datetime(6)
  updated_at : datetime(6)
}

table(product_images) {
  primary_key(id) : bigint
  --
  foreign_key(product_id) : bigint
  image_url : varchar(500)
  is_primary : bit(1)
  sort_order : int
  created_at : datetime(6)
}

table(inventory_log) {
  primary_key(id) : bigint
  --
  foreign_key(variant_id) : bigint
  foreign_key(user_id) : bigint
  quantity_change : int
  reason : varchar(255)
  note : text
  created_at : datetime(6)
}

' ==========================================
' CART & ORDERS
' ==========================================
table(carts) {
  primary_key(id) : bigint
  --
  foreign_key(user_id) : bigint <<UK>>
  session_id : varchar(255) <<UK>>
  created_at : datetime(6)
  updated_at : datetime(6)
}

table(cart_items) {
  primary_key(id) : bigint
  --
  foreign_key(cart_id) : bigint
  foreign_key(variant_id) : bigint
  quantity : int
  created_at : datetime(6)
  updated_at : datetime(6)
}

table(orders) {
  primary_key(id) : bigint
  --
  foreign_key(customer_id) : bigint
  foreign_key(address_id) : bigint
  foreign_key(promotion_id) : bigint
  order_number : varchar(50)
  order_status : enum('PENDING','PROCESSING','PREPARING','SHIPPING','DELIVERED','CANCELLED','RETURNED')
  payment_method : enum('COD','BANK_TRANSFER','VNPAY','MOMO')
  payment_status : enum('PENDING','PAID','FAILED','REFUNDED')
  subtotal : decimal(15,0)
  shipping_fee : decimal(15,0)
  discount_amount : decimal(15,0)
  total : decimal(15,0)
  snap_recipient_name : varchar(255)
  snap_phone : varchar(20)
  snap_address : text
  note : text
  cancelled_reason : text
  created_at : datetime(6)
  updated_at : datetime(6)
}

table(order_items) {
  primary_key(id) : bigint
  --
  foreign_key(order_id) : bigint
  foreign_key(variant_id) : bigint
  product_name : varchar(255)
  variant_size : varchar(50)
  price : decimal(15,0)
  quantity : int
  total : decimal(15,0)
  created_at : datetime(6)
}

table(order_status_history) {
  primary_key(id) : bigint
  --
  foreign_key(order_id) : bigint
  foreign_key(changed_by) : bigint
  old_status : enum
  new_status : enum
  note : text
  created_at : datetime(6)
}

table(payments) {
  primary_key(id) : bigint
  --
  foreign_key(order_id) : bigint
  transaction_id : varchar(255)
  payment_method : enum
  status : enum('PENDING','SUCCESS','FAILED')
  amount : decimal(15,0)
  payload : json
  created_at : datetime(6)
  updated_at : datetime(6)
}

' ==========================================
' PROMOTIONS & MARKETING
' ==========================================
table(promotions) {
  primary_key(id) : bigint
  --
  code : varchar(100) <<UK>>
  name : varchar(255)
  description : text
  type : enum('FIXED','PERCENTAGE')
  value : decimal(5,2)
  min_order_value : decimal(15,0)
  usage_limit : int
  used_count : int
  is_active : bit(1)
  start_date : datetime(6)
  end_date : datetime(6)
  created_at : datetime(6)
  updated_at : datetime(6)
}

table(promotion_conditions) {
  primary_key(id) : bigint
  --
  foreign_key(promotion_id) : bigint
  foreign_key(category_id) : bigint
  foreign_key(product_id) : bigint
  apply_to : enum('ALL','CATEGORY','PRODUCT')
  created_at : datetime(6)
}

table(banners) {
  primary_key(id) : bigint
  --
  title : varchar(255)
  image_url : varchar(500)
  link_url : varchar(500)
  sort_order : int
  is_active : bit(1)
  created_at : datetime(6)
  updated_at : datetime(6)
}

' ==========================================
' BLOG, REVIEWS & WISHLIST
' ==========================================
table(blog_posts) {
  primary_key(id) : bigint
  --
  foreign_key(author_id) : bigint
  title : varchar(255)
  slug : varchar(255) <<UK>>
  excerpt : text
  content : longtext
  featured_image : varchar(500)
  author_name : varchar(255)
  is_published : bit(1)
  published_at : datetime(6)
  created_at : datetime(6)
  updated_at : datetime(6)
}

table(reviews) {
  primary_key(id) : bigint
  --
  foreign_key(order_item_id) : bigint <<UK>>
  foreign_key(customer_id) : bigint
  foreign_key(product_id) : bigint
  rating : int
  comment : text
  admin_response : text
  status : enum('PENDING','APPROVED','REJECTED')
  created_at : datetime(6)
  updated_at : datetime(6)
}

table(review_images) {
  primary_key(id) : bigint
  --
  foreign_key(review_id) : bigint
  image_url : varchar(500)
  created_at : datetime(6)
}

table(wishlists) {
  primary_key(id) : bigint
  --
  foreign_key(customer_id) : bigint
  foreign_key(product_id) : bigint
  created_at : datetime(6)
}

' ==========================================
' RELATIONSHIPS (FOREIGN KEYS)
' ==========================================
users ||--o{ verification_tokens : "1:N"
users ||--o{ admin_actions_log : "1:N"
users ||--o| customers : "1:1 (user_id)"
users ||--o| carts : "1:1 (user_id)"
users ||--o{ inventory_log : "1:N"
users ||--o{ order_status_history : "1:N"
users ||--o{ blog_posts : "1:N"

customers ||--o{ addresses : "1:N"
customers ||--o{ orders : "1:N"
customers ||--o{ reviews : "1:N"
customers ||--o{ wishlists : "1:N"

carts ||--o{ cart_items : "1:N"
product_variants ||--o{ cart_items : "1:N"

categories ||--o{ categories : "1:N (parent_id)"
categories ||--o{ products : "1:N"
brands ||--o{ products : "1:N"
collections ||--o{ products : "1:N"
materials ||--o{ products : "1:N"

products ||--o{ product_variants : "1:N"
products ||--o{ product_images : "1:N"
products ||--o{ promotion_conditions : "1:N"
products ||--o{ reviews : "1:N"
products ||--o{ wishlists : "1:N"

product_variants ||--o{ inventory_log : "1:N"
product_variants ||--o{ order_items : "1:N"

promotions ||--o{ promotion_conditions : "1:N"
categories ||--o{ promotion_conditions : "1:N"
promotions ||--o{ orders : "1:N"

addresses ||--o{ orders : "1:N"

orders ||--o{ order_items : "1:N"
orders ||--o{ order_status_history : "1:N"
orders ||--o{ payments : "1:N"

order_items ||--o| reviews : "1:1 (order_item_id)"
reviews ||--o{ review_images : "1:N"

@enduml